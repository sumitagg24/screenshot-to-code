# Database (Optional - for future use)
# DATABASE_URL=postgresql://user:password@localhost:5432/screenshot_to_code?schema=public

# API Keys (Required - add your own)
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GEMINI_API_KEY=your-gemini-api-key
SCREENSHOTONE_API_KEY=your-screenshotone-api-key

# Optional: Image Generation (Replicate)
REPLICATE_API_TOKEN=your-replicate-token

# Optional: OpenAI Base URL (for proxies)
# OPENAI_BASE_URL=https://your-proxy.com/v1

# Debug Mode (development only)
IS_DEBUG_ENABLED=false

# Production Flag (set to true when deployed)
IS_PROD=false
