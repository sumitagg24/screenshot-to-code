# Backend WebSocket URL (for client-side WebSocket connection)
# Note: /generate-code is appended automatically by the frontend code
NEXT_PUBLIC_WS_BACKEND_URL=ws://localhost:8000

# Backend HTTP URL (for future API calls)
NEXT_PUBLIC_HTTP_BACKEND_URL=http://localhost:8000

# ScreenshotOne API key (optional — needed for URL tab)
# Register at https://screenshotone.com
# NEXT_PUBLIC_SCREENSHOTONE_API_KEY=
